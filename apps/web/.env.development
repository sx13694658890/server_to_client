# 开发期留空：请求走相对路径 /api/v1/...，由 Vite 代理到后端（见 vite.config.ts）
VITE_API_BASE_URL=

# 代理目标，默认 http://127.0.0.1:8000
VITE_PROXY_TARGET=http://127.0.0.1:8000

# 若浏览器直连后端（且后端已开 CORS），可改为完整 origin，例如：
# VITE_API_BASE_URL=http://127.0.0.1:8000

# AI 聊天：默认 POST /api/v1/ai/chat；设为 true 则走 SSE 流式
VITE_AI_CHAT_USE_STREAM=true

# 流式回复「逐字露出」节奏（毫秒），默认 68；可调到 90～120 更明显
# VITE_AI_CHAT_STREAM_TICK_MS=90

# 浮标位置 left | right
# VITE_AI_CHAT_FAB_POSITION=left
